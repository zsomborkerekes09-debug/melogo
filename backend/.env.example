# MelóGo Backend Környezeti Változók (Sablon)
# Másold le ezt a fájlt .env néven, és töltsd ki a saját kulcsaiddal!

PORT=5000

# Stripe Konfiguráció (A Stripe.com Developer felületéről)
STRIPE_PUBLISHABLE_KEY=pk_test_töltsd_ki_a_saját_kulcsoddal
STRIPE_SECRET_KEY=sk_test_töltsd_ki_a_saját_kulcsoddal

# Gemini AI Konfiguráció (A Google AI Studio-ból: https://aistudio.google.com/)
GEMINI_API_KEY=töltsd_ki_a_saját_gemini_kulcsoddal

# Platform Beállítások
PLATFORM_FEE_PERCENT=5
