rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===========================
    // JOBS collection
    // ===========================
    match /jobs/{jobId} {
      // Anyone authenticated can read open jobs (worker home screen filter)
      allow read: if request.auth != null;
      // Only the owner (employer) can write their own job
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // ===========================
    // APPLICATIONS collection
    // ===========================
    match /applications/{appId} {
      allow read, write: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.workerUid ||
        request.auth.uid == resource.data.employerUid ||
        request.auth.email == resource.data.workerEmail ||
        request.auth.email == resource.data.employerEmail
      );
    }

    // ===========================
    // CHATS collection + messages subcollection
    // ===========================
    match /chats/{chatId} {
      // Only the worker and employer of the chat can access it
      allow read, write: if request.auth != null && (
        request.auth.uid == resource.data.workerId ||
        request.auth.uid == resource.data.employerId
      );
      // Allow chat creation by the worker (workerId == their UID)
      allow create: if request.auth != null && request.resource.data.workerId == request.auth.uid;

      // Messages subcollection – same access as parent chat
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.workerId == request.auth.uid ||
          get(/databases/$(database)/documents/chats/$(chatId)).data.employerId == request.auth.uid
        );
        allow create: if request.auth != null && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.workerId == request.auth.uid ||
          get(/databases/$(database)/documents/chats/$(chatId)).data.employerId == request.auth.uid
        );
        // System messages can be created by any party (senderId == 'system')
        allow update, delete: if false; // messages are immutable
      }
    }

    // ===========================
    // USERS collection
    // ===========================
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
