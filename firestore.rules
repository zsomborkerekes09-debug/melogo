rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===========================
    // JOBS collection
    // ===========================
    match /jobs/{jobId} {
      // Anyone authenticated can read open jobs (worker home screen filter)
      allow read: if request.auth != null;
      // Only the owner (employer) can create their own job and the ownerUid must match
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // ===========================
    // APPLICATIONS collection
    // ===========================
    match /applications/{appId} {
      // Workers can create applications — but workerUid MUST match their own UID (no spoofing)
      allow create: if request.auth != null
        && request.resource.data.workerUid == request.auth.uid;

      // Read: only the worker or the employer of this application can read it
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.workerUid ||
        request.auth.uid == resource.data.employerUid
      );

      // Update: only the involved parties can update (e.g. employer accepts/rejects)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.workerUid ||
        request.auth.uid == resource.data.employerUid
      );

      // Delete: worker who created it can delete, or employer can delete (cascade delete)
      allow delete: if request.auth != null && (request.auth.uid == resource.data.workerUid || request.auth.uid == resource.data.employerUid);
    }

    // ===========================
    // CHATS collection + messages subcollection
    // ===========================
    match /chats/{chatId} {
      // Allow chat creation by the worker (workerId must be their own UID)
      allow create: if request.auth != null
        && request.resource.data.workerId == request.auth.uid;

      // Only the worker and employer of the chat can read or update it.
      // Also allow by ownerUid of the related job as a safe fallback.
      allow read, update: if request.auth != null && (
        request.auth.uid == resource.data.workerId ||
        request.auth.uid == resource.data.employerId ||
        (resource.data.jobId != null &&
          exists(/databases/$(database)/documents/jobs/$(resource.data.jobId)) &&
          request.auth.uid == get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.ownerUid)
      );

      // Allow deletion by either party (useful for cascade deletes when job is removed)
      allow delete: if request.auth != null && (request.auth.uid == resource.data.workerId || request.auth.uid == resource.data.employerId);

      // Messages subcollection – same access as parent chat
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.workerId == request.auth.uid ||
          get(/databases/$(database)/documents/chats/$(chatId)).data.employerId == request.auth.uid ||
          (get(/databases/$(database)/documents/chats/$(chatId)).data.jobId != null &&
            exists(/databases/$(database)/documents/jobs/$(get(/databases/$(database)/documents/chats/$(chatId)).data.jobId)) &&
            request.auth.uid == get(/databases/$(database)/documents/jobs/$(get(/databases/$(database)/documents/chats/$(chatId)).data.jobId)).data.ownerUid)
        );
        allow create: if request.auth != null && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.workerId == request.auth.uid ||
          get(/databases/$(database)/documents/chats/$(chatId)).data.employerId == request.auth.uid ||
          (get(/databases/$(database)/documents/chats/$(chatId)).data.jobId != null &&
            exists(/databases/$(database)/documents/jobs/$(get(/databases/$(database)/documents/chats/$(chatId)).data.jobId)) &&
            request.auth.uid == get(/databases/$(database)/documents/jobs/$(get(/databases/$(database)/documents/chats/$(chatId)).data.jobId)).data.ownerUid)
        );
        // Messages are immutable once created
        allow update, delete: if false;
      }
    }

    // ===========================
    // USERS collection
    // ===========================
    match /users/{userId} {
      // Any authenticated user can read user profiles.
      // Phone numbers are only revealed post-acceptance in the app UI (enforced in JS).
      allow read: if request.auth != null;
      // Only the user themselves can write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

