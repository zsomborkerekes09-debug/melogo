rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global rule: allow anyone to read public profiles, jobs, etc.
    // For a real app, you'd restrict this more.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;
    }
    
    match /chats/{chatId} {
      // Allow if user is either the worker or the employer
      allow read, update, delete: if request.auth != null && (
        request.auth.uid == resource.data.workerId || 
        request.auth.uid == resource.data.employerId
      );
      // Anyone can create if they are logged in (to start a chat)
      allow create: if request.auth != null;
    }
    
    match /applications/{appId} {
      // Allow if user is either the worker or the employer
      allow read, update, delete: if request.auth != null && (
        request.auth.uid == resource.data.workerUid || 
        request.auth.uid == resource.data.employerUid
      );
      allow create: if request.auth != null;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
  }
}
